{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git remote -v)",
      "Bash(git branch*)",
      "Bash(git rev-parse*)",
      "Bash(git ls-files*)",
      "Bash(git blame*)",
      "Bash(git stash list*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(find . *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(tree *)",
      "Bash(python3 -c *)",
      "Bash(python3 -m pytest*)",
      "Bash(python3 -m pip list*)",
      "Bash(python3 -m pip show*)",
      "Bash(pytest*)",
      "Bash(ruff check*)",
      "Bash(mypy *)",
      "Bash(node -e *)",
      "Bash(node --check *)",
      "Bash(npm ls*)",
      "Bash(openclaw --version)",
      "Bash(openclaw status*)",
      "Bash(openclaw config validate*)",
      "Bash(openclaw doctor*)",
      "Bash(openclaw models list*)",
      "Bash(openclaw models status*)",
      "Bash(openclaw models fallbacks list*)",
      "Bash(openclaw help*)",
      "Bash(openclaw security audit*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh api repos/*/actions/*)",
      "Bash(gitleaks detect*)",
      "WebFetch(domain:docs.api.nvidia.com)",
      "WebFetch(domain:build.nvidia.com)",
      "WebFetch(domain:core.telegram.org)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "Skill(*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf .git*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fdx*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(history -c*)",
      "Bash(rm /workspaces/openclaw-lab/data/*.db)",
      "Bash(rm /workspaces/openclaw-lab/logs/*.jsonl)",
      "Bash(rm /workspaces/openclaw-lab/.env*)",
      "Bash(cat ~/.openclaw/openclaw.json*)",
      "Bash(cat ~/.openclaw/agents/main/agent/auth-profiles.json*)",
      "Bash(curl*-d*NVIDIA_API_KEY*)",
      "Bash(echo*$NVIDIA_API_KEY*)",
      "Bash(echo*$TELEGRAM_BOT_TOKEN*)",
      "Bash(printenv*NVIDIA*)",
      "Bash(printenv*TELEGRAM*)",
      "Bash(env*NVIDIA*)",
      "Bash(env*TELEGRAM*)",
      "Read(~/.openclaw/agents/main/agent/auth-profiles.json)",
      "Read(./.env)",
      "Write(./.env)",
      "Edit(./.env)"
    ]
  },
  "env": {
    "CAVEMAN_DEFAULT_MODE": "full"
  }
}
