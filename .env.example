# ─────────────────────────────────────────────────────────────────────────────
# OpenClaw Lab — Environment variable template
#
# Copy to `.env` (gitignored) and fill in real values, OR set as Codespaces
# secrets at: GitHub repo → Settings → Secrets and variables → Codespaces.
#
# All values shown are placeholders. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# NVIDIA NIM API key. Single key unlocks all 42 verified-live models.
# Get one at: https://build.nvidia.com  (free tier available)
NVIDIA_API_KEY=nvapi-replace-with-real-key

# ── TELEGRAM ──────────────────────────────────────────────────────────────────

# Bot token from @BotFather. Configured in ~/.openclaw/openclaw.json as well;
# this env var is consumed by ad-hoc scripts that need direct API access.
TELEGRAM_BOT_TOKEN=0000000000:replace-with-real-bot-token

# Numeric chat id the bot sends to (your own user id or a group id).
# Find yours by messaging @userinfobot.
TELEGRAM_CHAT_ID=000000000

# Comma-separated allowlist of Telegram user ids permitted to talk to the bot.
# Anyone NOT on this list is silently ignored. Required when bot is public.
ALLOWED_TG_USER_IDS=000000000

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# Override default compression model used by /caveman-compress.
# Default: nvidia/nemotron-3-super-120b-a12b
CAVEMAN_MODEL=

# Default caveman mode at SessionStart. One of:
#   off | lite | full | ultra | wenyan-lite | wenyan-full | wenyan-ultra
# Default: full
CAVEMAN_DEFAULT_MODE=

# Path the audit logger writes to. JSONL, append-only.
# Default: <repo>/logs/audit.jsonl
OPENCLAW_AUDIT_LOG=

# Set to 1 to enable verbose hook diagnostics on stderr.
CAVEMAN_DEBUG=
